# ===== 必填 =====
DASHSCOPE_API_KEY=sk-your-key-here

# ===== 数据库（PostgreSQL + Redis）=====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/course_agent
REDIS_URL=redis://localhost:6379/0

# ===== JWT 认证 =====
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=72

# ===== CORS（生产环境务必改为实际域名，多个用逗号分隔）=====
# 开发环境可用 *，生产请设为具体域名，例如：
# ALLOWED_ORIGINS=https://my-app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# ===== LLM 模型（默认用 Plus 档，比 Max 便宜；更省可改 qwen-flash / qwen-turbo）=====
# TEXT_MODEL=qwen-plus
# VISION_MODEL=qwen-vl-plus
# 更省钱（质量略降）：TEXT_MODEL=qwen-flash 或 qwen-turbo
# 视觉更省：VISION_MODEL=qwen-vl-plus（已默认；需最强再改 qwen-vl-max）
# EMBEDDING_MODEL=text-embedding-v3
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== RAG 参数 =====
# RAG_BACKEND=fs              # fs | chroma（Windows 默认 fs）
# CHUNK_SIZE=500
# CHUNK_OVERLAP=80
# TOP_K=4

# ===== LightRAG（默认关闭；开启后可用 /api/chat/lightrag）=====
# LIGHTRAG_ENABLED=false
# LIGHTRAG_WORKDIR=./lightrag_store
# LIGHTRAG_QUERY_MODE=mix         # local | global | hybrid | naive | mix | bypass
# LIGHTRAG_TOP_K=20
# LIGHTRAG_TIMEOUT_SEC=120
# LIGHTRAG_EMBEDDING_DIM=1024
# LIGHTRAG_AUTO_INDEX_TTL_SEC=120 # 自动索引检查的最小间隔秒数，降低连续提问延迟
# LIGHTRAG_STREAM_CONTEXT_LIMIT=4  # 流式回答拼接的证据条数上限
# LIGHTRAG_STREAM_CONTEXT_MAX_CHARS=800 # 单条证据最大字符数，控制 prompt 体积
# INGEST_CHUNK_SIZE=900
# INGEST_CHUNK_OVERLAP=60

# ===== 文件上传 =====
# MAX_UPLOAD_MB=10

# ===== 路径（一般不需要改）=====
# UPLOAD_DIR=./uploads
# KNOWLEDGE_DIR=./knowledge
# VECTORSTORE_DIR=./vectorstore
# DB_PATH=./data/sessions.db    # 仅供 SQLite 迁移脚本读取旧数据
